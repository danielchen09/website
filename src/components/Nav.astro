---
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/#work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/#contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 backdrop-blur bg-[var(--color-bg)]/80 border-b border-[var(--color-border)]">
  <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-mono text-sm tracking-tight text-[var(--color-ink)] hover:text-accent-500 transition-colors">
      wei-han chen
    </a>
    <nav class="flex items-center gap-6">
      <ul class="hidden sm:flex items-center gap-6 text-sm text-[var(--color-ink-muted)]">
        {links.map((link) => (
          <li>
            <a href={link.href} class="hover:text-accent-500 transition-colors">{link.label}</a>
          </li>
        ))}
      </ul>
      <ThemeToggle />
    </nav>
  </div>
</header>
